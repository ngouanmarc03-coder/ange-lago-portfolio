# === Base de données MongoDB Atlas ===
# Va sur https://cloud.mongodb.com, crée un cluster gratuit (M0)
# puis récupère la connection string dans "Connect" > "Drivers"
MONGO_URI=mongodb+srv://<utilisateur>:<motdepasse>@<cluster>.mongodb.net/ange-lago?retryWrites=true&w=majority

# === Cloudinary (stockage images/vidéos) ===
# Sur https://cloudinary.com/console tu trouves ces 3 infos directement
CLOUDINARY_CLOUD_NAME=ton_cloud_name
CLOUDINARY_API_KEY=ton_api_key
CLOUDINARY_API_SECRET=ton_api_secret

# === Sécurité Admin ===
# Le mot de passe que TOI seul connais pour te connecter à la page admin
ADMIN_PASSWORD=change-moi-en-un-mot-de-passe-fort

# Une longue chaîne aléatoire secrète, sert à sécuriser la session admin
# Génère-en une ici : https://randomkeygen.com (choisis "CodeIgniter Encryption Keys")
JWT_SECRET=remplace-par-une-longue-chaine-aleatoire-secrete

# === CORS ===
# L'URL de ton site une fois en ligne sur Netlify (tu la mettras après le 1er déploiement)
# Exemple : https://ange-lago.netlify.app puis plus tard https://angelago.com
FRONTEND_URL=http://localhost:5500

# === Port (Railway le définit automatiquement, ne pas y toucher en prod) ===
PORT=5000
